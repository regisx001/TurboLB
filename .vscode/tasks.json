{
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: gcc build active file",
			"command": "/usr/bin/gcc",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"-I",
				"${workspaceFolder}/include",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"detail": "Task generated by Debugger."
		},
		{
			"label": "CMake: build TurboLB",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/build"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": [
				"$gcc"
			],
			"detail": "Build TurboLB using CMake (includes proper include paths)"
		},
		{
			"type": "cppbuild",
			"label": "C/C++: g++ build active file",
			"command": "/usr/bin/g++",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"-I",
				"${workspaceFolder}/include",
				"${workspaceFolder}/src/main.cpp",
				"${workspaceFolder}/src/http/HttpParser.cpp",
				"${workspaceFolder}/src/server/Server.cpp",
				"-o",
				"${workspaceFolder}/build/TurboLB"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Build TurboLB with g++ (includes all source files and include paths). For full project builds, use the CMake task instead."
		},
		{
			"label": "CMake: build TurboLB",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/build"
			],
			"group": "build"
		}
	],
	"version": "2.0.0"
}